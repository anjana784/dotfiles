# ~/.secrets — API keys and sensitive environment variables
#
# HOW TO USE:
#   1. Copy this template:  cp .secrets.template .secrets
#   2. Set permissions:      chmod 600 .secrets
#   3. Fill in your keys below
#
# This file is sourced by ~/.zshrc.
# DO NOT COMMIT .secrets TO ANY REPOSITORY.

# Cloudflare
export CLOUDFLARE_ACCOUNT_ID="your-account-id-here"

# DeepSeek API (used as Anthropic-compatible backend for Claude Code)
export ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
export ANTHROPIC_AUTH_TOKEN=sk-your-deepseek-api-key
export ANTHROPIC_MODEL=deepseek-v4-pro[1m]
export ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
export ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
export ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
export CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
export CLAUDE_CODE_EFFORT_LEVEL=max
